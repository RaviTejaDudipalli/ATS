NODE_ENV="development"
PORT=4000

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ats?schema=public"

# --- Auth ---
# Use strong, distinct, long random secrets in production. 64+ bytes.
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"            # short-lived access token
JWT_REFRESH_TTL_DAYS=30         # refresh token lifetime
BCRYPT_COST=12

# --- HTTP ---
CORS_ORIGIN="http://localhost:3000"   # comma-separated for multiple origins
TRUST_PROXY=0                          # set to 1 behind a load balancer

# --- Cookies / CSRF ---
# Long random string. REQUIRED in production. Falls back to JWT_SECRET in dev.
CSRF_SECRET="change-me-csrf-secret-at-least-16-chars"
# 'lax' for same-site (most setups). Use 'none' (with COOKIE_SECURE=true)
# only when frontend and backend live on different registrable domains.
COOKIE_SAMESITE="lax"
# Force HTTPS-only cookies. Auto-on in production; opt in for HTTPS staging.
# COOKIE_SECURE="true"
# Cookie domain. Leave empty for host-only cookies. Use ".example.com" to
# share auth across app.example.com + api.example.com.
# COOKIE_DOMAIN=""

# --- Rate limiting ---
RATE_LIMIT_GLOBAL_PER_MIN=300
RATE_LIMIT_AUTH_PER_15M=20
RATE_LIMIT_UPLOAD_PER_HOUR=20

# --- File storage ---
UPLOAD_DIR="uploads"
MAX_RESUME_BYTES=10485760              # 10 MB

# --- Background scoring queue ---
# When set, BullMQ + Redis is used. Otherwise an in-process queue runs jobs.
# REDIS_URL="redis://localhost:6379"

# --- Logging ---
LOG_LEVEL="info"                       # silent|fatal|error|warn|info|debug|trace
